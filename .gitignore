dist/
build/
.eggs/
MANIFEST
*.pyo

# ── Virtual environments ─────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.env

# ── Distribution / packaging ─────────────────────────────────────────────────
*.tar.gz
*.whl

