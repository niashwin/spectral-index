*.ipynb

# ── IDEs ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── HuggingFace model cache (can be large, no need to commit) ────────────────
# If you cache models locally, exclude the cache dir:
.cache/
hf_cache/
model_cache/

# ── Partial / crash-recovery saves (these are transient) ─────────────────────
results/*.partial.json

# ── Secrets ───────────────────────────────────────────────────────────────────
.env
*.env
secrets.json

# ────────────────────────────────────────────────────────────────────────────
# NOTE: results/ is NOT ignored — we commit measurement data to the repo.
